{
  "entities": {
    "User": {
      "title": "User",
      "description": "User profile and settings",
      "type": "object",
      "properties": {
        "nodeId": { "type": "string", "description": "The user's Meshtastic Node ID" },
        "lastSeen": { "type": "string", "format": "date-time", "description": "Last time the user was active" }
      },
      "required": ["nodeId"]
    },
    "Log": {
      "title": "Log",
      "description": "A single serial log entry",
      "type": "object",
      "properties": {
        "text": { "type": "string", "description": "The log message text" },
        "type": { "type": "string", "enum": ["info", "success", "warning", "error", "serial"], "description": "Type of log" },
        "timestamp": { "type": "string", "description": "Human readable timestamp" },
        "createdAt": { "type": "string", "format": "date-time", "description": "Server timestamp for sorting" }
      },
      "required": ["text", "type", "timestamp", "createdAt"]
    },
    "RelayNode": {
      "title": "RelayNode",
      "description": "Stats for a specific relay node",
      "type": "object",
      "properties": {
        "byte": { "type": "string", "description": "The relay node byte identifier" },
        "entries": { 
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "id": { "type": "string" },
              "snr": { "type": "string" },
              "rssi": { "type": "string" }
            }
          }
        },
        "updatedAt": { "type": "string", "format": "date-time" }
      },
      "required": ["byte", "entries", "updatedAt"]
    }
  },
  "firestore": {
    "/users/{userId}": {
      "schema": "User",
      "description": "User settings"
    },
    "/users/{userId}/logs/{logId}": {
      "schema": "Log",
      "description": "User's serial logs"
    },
    "/users/{userId}/relays/{relayId}": {
      "schema": "RelayNode",
      "description": "Relay statistics per node"
    }
  }
}
